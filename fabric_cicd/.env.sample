# Target Fabric workspace (required)
FABRIC_WORKSPACE_ID=00000000-0000-0000-0000-000000000000

# parameter.yml environment key (DEV / PPE / PROD).
# deploy.py also loads .env.<lowercased value> as an overlay if present,
# e.g. .env.dev / .env.ppe / .env.prod. Overlay values override .env.
FABRIC_ENVIRONMENT=DEV

# Azure subscription ID hosting the Log Analytics / App Insights resources
# referenced by Fabric items. Substituted into parameter.yml via
# $ENV:FABRIC_SUBSCRIPTION_ID.
FABRIC_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Azure resource group hosting the Log Analytics / App Insights resources
# referenced by Fabric items (Notebook, KQL queryset, KQL dashboard).
# Substituted into parameter.yml via $ENV:FABRIC_RESOURCE_GROUP.
FABRIC_RESOURCE_GROUP=rg-aictt-dev

# Log Analytics workspace name referenced by Fabric items.
# Substituted into parameter.yml via $ENV:FABRIC_LAW_NAME.
FABRIC_LAW_NAME=aictt-law-dev

# Application Insights component name referenced by Fabric items.
# Substituted into parameter.yml via $ENV:FABRIC_AI_NAME.
FABRIC_AI_NAME=aictt-ai-dev

# ADLS Gen2 storage account name referenced by Lakehouse shortcuts
# (shortcuts.metadata.json). Substituted into parameter.yml via
# $ENV:FABRIC_STORAGE_ACCOUNT.
FABRIC_STORAGE_ACCOUNT=aicttsadev

# Fabric cloud connection GUID bound to the ADLS Gen2 shortcuts. The
# connection's configured URL in the target Fabric tenant must exactly match
# https://<FABRIC_STORAGE_ACCOUNT>.dfs.core.windows.net (no trailing slash) or
# shortcut publish fails with DMTSConnectionServerAndTargetPathMismatch.
# Substituted into parameter.yml via $ENV:FABRIC_ADLS_CONNECTION_ID.
# manually create the connection in the Fabric tenant and set this value before deployment
FABRIC_ADLS_CONNECTION_ID=d1f69d26-5f05-4e5a-abff-93e98cc061ff

# Optional flags
FABRIC_DEBUG=false
FABRIC_UNPUBLISH_ORPHANS=false
