# DEV overlay for fabric-cicd. Loaded by deploy.py after .env when
# FABRIC_ENVIRONMENT=DEV. Values here override .env.

# Target Fabric workspace (DEV)
FABRIC_WORKSPACE_ID=5662e90c-c128-4d18-a1b9-9fe24a816fbd

# parameter.yml environment key
FABRIC_ENVIRONMENT=DEV

# Azure subscription ID for Log Analytics / App Insights resources
FABRIC_SUBSCRIPTION_ID=873a4995-e21b-47e2-953e-f2e88e2fa4f9

# Azure resource group for Log Analytics / App Insights resources
FABRIC_RESOURCE_GROUP=rg-aictt-dev

# Log Analytics workspace name
FABRIC_LAW_NAME=aictt-law-dev

# Application Insights component name
FABRIC_AI_NAME=aictt-ai-dev

# Optional flags
FABRIC_DEBUG=false
FABRIC_UNPUBLISH_ORPHANS=false
