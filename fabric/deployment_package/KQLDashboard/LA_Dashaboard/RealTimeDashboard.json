  "queries": [
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "59a97410-d842-422c-99b9-9879fa4e26a9"
      },
      "text": "AppRequests\n| where TimeGenerated >= _startTime and TimeGenerated <= _endTime\n| summarize countAppRequests=count() by bin(TimeGenerated, 5m)\n| render timechart\n",
      "id": "12727aaa-5eb5-4fac-a5a5-eee964b01257",
      "usedVariables": [
        "_endTime",
        "_startTime"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "59a97410-d842-422c-99b9-9879fa4e26a9"
      },
      "text": "\nAppRequests\n| where TimeGenerated >= _startTime and TimeGenerated <= _endTime\n| summarize requestCount=count() by bin(TimeGenerated, 1d)\n| render columnchart  with (\n    title=\"App Requests Over Time (Last 30 Days, Daily)\",\n    xtitle=\"Date\",\n    ytitle=\"Request Count\"\n)",
      "id": "f4ae24fd-33c8-4aea-862a-a94d9673a324",
      "usedVariables": [
        "_endTime",
        "_startTime"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "fa5c3f20-c7e3-485b-ae97-b81b0c817877"
      },
      "text": "union isfuzzy=true\r\n    requests,\r\n    traces,\r\n    customEvents,\r\n    dependencies\r\n| where timestamp >= _startTime and timestamp <= _endTime\r\n| order by timestamp desc\r\n| limit 100",
      "id": "0309c389-55eb-431c-a485-e3dd27a65d69",
      "usedVariables": [
        "_endTime",
        "_startTime"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "fa5c3f20-c7e3-485b-ae97-b81b0c817877"
      },
      "text": "union isfuzzy=true requests, traces, customEvents, dependencies\r\n| where timestamp >= ago(7d) and timestamp <= now()\r\n| where tostring(customDimensions[\"microsoft.foundry\"]) == \"True\"\r\n    and tostring(customDimensions[\"span_type\"]) == \"agent\"\r\n| summarize count=count() by agent=tostring(customDimensions[\"gen_ai.agent.id\"])\r\n| render barchart with (xtitle=\"agent\", ytitle=\"count\")",
      "id": "e526085c-effc-4072-891e-0ef454ab7883",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "fa5c3f20-c7e3-485b-ae97-b81b0c817877"
      },
      "text": "union isfuzzy=true requests, traces, customEvents, dependencies\r\n| where timestamp >= ago(7d) and timestamp <= now()\r\n| where tostring(customDimensions[\"microsoft.foundry\"]) == \"True\"\r\n    and tostring(customDimensions[\"span_type\"]) == \"agent\"\r\n| summarize inputTokens=sum(toint(customDimensions[\"gen_ai.usage.input_tokens\"])) by agent=tostring(customDimensions[\"gen_ai.agent.id\"])\r\n| render barchart with (xtitle=\"agent\", ytitle=\"input tokens\")",
      "id": "7498ec64-a74c-43f8-acdd-ec7f0f368e4b",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "fa5c3f20-c7e3-485b-ae97-b81b0c817877"
      },
      "text": "let _startTime = datetime(2026-04-28T11:10:24Z);\r\nlet _endTime = datetime(2026-04-28T12:10:24Z);\r\nunion isfuzzy=true requests, traces, customEvents, dependencies\r\n| where timestamp >= _startTime and timestamp <= _endTime\r\n| where tostring(customDimensions[\"microsoft.foundry\"]) == \"True\"\r\n    and tostring(customDimensions[\"span_type\"]) == \"agent\"\r\n| make-series avgDurationMinutes=avg(duration/60000.0) on timestamp from _startTime to _endTime step 1m\r\n| render timechart \r\n    with (\r\n        xtitle=\"Date\",\r\n        ytitle=\"Average Duration (minutes)\",\r\n        legend=hidden\r\n    )",
      "id": "b3531efa-460b-4826-8017-702dc8f6fb9f",
      "usedVariables": []
    }
  ]
}